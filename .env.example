# Configuração de Produção - Prontuario IA
# Copie este arquivo para .env e ajuste os valores

# Chave da API (obrigatório)
# Exemplos:
# - Anthropic: sk-ant-...
# - OpenAI: sk-...
# - DeepSeek: sk-bfe435b4b1d1472f818cbc298fedcc95
API_KEY=sk-bfe435b4b1d1472f818cbc298fedcc95

# Provedor (opcional, padrão: anthropic)
# Valores: anthropic, openai, groq, openrouter, deepseek
API_PROVIDER=deepseek

# Modelo específico (opcional)
# Se vazio, usa o modelo padrão do provedor
API_MODEL=deepseek-chat

# Origens permitidas para CORS (opcional, padrão: *)
# Em produção, especifique as URLs do seu frontend separadas por vírgula
# Exemplo: https://seusite.com,https://app.seusite.com
ALLOWED_ORIGINS=*

# Nível de log (opcional, padrão: INFO)
# Valores: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Porta do servidor (opcional, padrão: 8080)
PORT=8080